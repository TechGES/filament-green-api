{
    "name": "ges/filament-green-api",
    "description": "Filament admin pages for configuring and using the Laravel Green API package.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/TechGES/filament-green-api",
    "keywords": [
        "filament-v3",
        "filament-plugin",
        "filament",
        "green-api",
        "laravel",
        "package",
        "whatsapp"
    ],
    "authors": [
        {
            "name": "TechGES",
            "homepage": "https://github.com/TechGES"
        }
    ],
    "support": {
        "issues": "https://github.com/TechGES/filament-green-api/issues",
        "source": "https://github.com/TechGES/filament-green-api"
    },
    "require": {
        "php": "^8.4",
        "filament/filament": "^3.3",
        "ges/laravel-green-api": "^0.1",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Ges\\FilamentGreenApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ges\\FilamentGreenApi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ges\\FilamentGreenApi\\GreenApiServiceProvider"
            ]
        }
    }
}
